# Sprint Tracker — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored (see .gitignore `.env*`); never commit real secrets.

# ─────────────────────────────────────────────────────────────────────────────
# Database (Prisma 7 + Postgres / Neon)
# ─────────────────────────────────────────────────────────────────────────────
# Neon gives a POOLED connection string (PgBouncer, host has `-pooler`). Use it as DATABASE_URL —
# it is what the app's runtime PrismaClient (via @prisma/adapter-pg) and Prisma Migrate both read.
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
#
# Example (Neon, pooled):
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/sprint_tracker?sslmode=require"
#
# Example (local Postgres, for development without Neon):
#   DATABASE_URL="postgresql://localhost:5432/sprint_tracker_dev"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optional: a DIRECT (non-pooled) connection for Prisma Migrate. Some pooled providers (Neon's
# PgBouncer in transaction mode) cannot run migrations; if so, set DIRECT_URL to the non-pooled
# host (no `-pooler`) and wire `directUrl` into prisma.config.mjs's datasource. Unused by default.
#   DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/sprint_tracker?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# Bootstrap seed (prisma/seed.mjs — `yarn db:seed`)
# ─────────────────────────────────────────────────────────────────────────────
# Email of the bootstrap ADMIN user the seed creates and flags `isAdmin: true`. This is the seed's
# INPUT only (which user to make admin); RBAC reads the User.isAdmin column, not this var. The
# user's real Jira account id is filled in on first login (seeded as a `seed-pending:` placeholder).
SEED_ADMIN_EMAIL="you@tekion.com"

# ─────────────────────────────────────────────────────────────────────────────
# Auth layer (migration step 3 — login/me/logout route handlers)
# ─────────────────────────────────────────────────────────────────────────────
# Jira Cloud site URL. The REST base is `${JIRA_BASE_URL}/rest/api/3`; the tenant cloudId is
# discovered at login from `${JIRA_BASE_URL}/_edgeProxy/tenant_info` (no JIRA_CLOUD_ID var needed).
JIRA_BASE_URL="https://tekion.atlassian.net"

# Two DISTINCT secrets — in prod both come from Tekion's secret store, never committed:
#   SESSION_PASSWORD     seals the iron-session cookie (≥ 32 chars).
#   TOKEN_ENCRYPTION_KEY AES-256-GCM key for JiraCredential.encryptedToken (base64 of 32 bytes).
# Generate each with:  openssl rand -base64 32
SESSION_PASSWORD="change-me-to-a-32+-char-random-string"
TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# ─────────────────────────────────────────────────────────────────────────────
# Background job (migration step 7 — POST /api/cron/daily)
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret gating the cron route (`Authorization: Bearer <CRON_SECRET>` — the route has no
# session). ≥ 32 chars; from the secret store in prod; read lazily at call time and fails loudly
# if unset. Generate with:  openssl rand -base64 32
CRON_SECRET="change-me-to-a-32+-char-random-string"

# Email of the User whose stored (encrypted) JiraCredential the daily Issue-cache refresh runs
# with — they must have logged in at least once. ⚠️ Per-user tokens see per-user data (§13.2):
# this user's token must be able to browse EVERY team's Jira projects. Absent user/dead token →
# the job still writes SprintSnapshot rows (from the last-synced cache) but skips the Jira
# refresh and says why in the run summary.
CRON_SYNC_USER_EMAIL="you@tekion.com"

# Scheduling is a deploy-time task on Tekion infra (out of repo scope). Example (daily 19:00):
#   0 19 * * * curl -sf -X POST -H "Authorization: Bearer $CRON_SECRET" https://<internal-host>/api/cron/daily

# ─────────────────────────────────────────────────────────────────────────────
# AI insights (post-v1 — provider-agnostic "AI Digest", ai-insights.md)
# ─────────────────────────────────────────────────────────────────────────────
# Which provider answers `generateJson` calls. Leave UNSET to disable the feature entirely
# (no Hero button; the route answers 503). Both provider keys may be set at once — switching
# providers (downtime, cost, any reason) is just flipping this value and restarting.
#   AI_PROVIDER="gemini"        # or "anthropic"
#
# Per-provider API keys (only the selected provider's key is required; missing → loud 500):
#   GEMINI_API_KEY="..."        # https://aistudio.google.com/apikey
#   ANTHROPIC_API_KEY="..."     # https://platform.claude.com
#
# Optional model override — the cost lever. Defaults live in src/lib/ai/provider.js
# (gemini-3.5-flash / claude-opus-4-8); set e.g. a cheaper tier here without code changes:
#   AI_MODEL="gemini-3.5-flash"
#
# Advanced (tests/proxies only): override a provider's endpoint base URL.
#   GEMINI_BASE_URL="http://127.0.0.1:4041"
#   ANTHROPIC_BASE_URL="http://127.0.0.1:4042"
